# Chat streaming Lambda (Node) + frontend build read from here
ANTHROPIC_API_KEY=sk-ant-...        # backend only — never exposed to the browser
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_KEY=<supabase-publishable-key>   # respects RLS

# Frontend (Vite, VITE_ prefix is exposed to the browser)
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_KEY=<supabase-publishable-key>
VITE_CHAT_URL=http://localhost:8000   # local only; on deploy SST injects the Chat Function URL
